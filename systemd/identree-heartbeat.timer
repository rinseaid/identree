[Unit]
Description=identree agent heartbeat — every 60 seconds
Requires=identree-heartbeat.service

[Timer]
OnBootSec=30s
OnUnitActiveSec=60s
# Spread heartbeats across hosts so a fleet of 100 doesn't hit the server simultaneously.
RandomizedDelaySec=10s
AccuracySec=5s

[Install]
WantedBy=timers.target
